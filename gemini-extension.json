{
  "name": "gemini-llm-council",
  "description": "Gemini CLI Extension to work with multiple LLMs at once",
  "version": "0.4.2",
  "contextFileName": "GEMINI.md",
  "settings": [
    {
      "name": "OpenRouter API Key",
      "description": "Your OpenRouter API key. Get one at https://openrouter.ai/keys\n(sk-or-v1-...)",
      "envVar": "OPENROUTER_API_KEY",
      "sensitive": true
    }
  ],
  "mcpServers": {
    "council": {
      "command": "node",
      "args": [
        "${extensionPath}/dist/index.js"
      ],
      "env": {
        "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "command": "hooks/check-env.sh"
      }
    ],
    "BeforeTool": [
      {
        "command": "node hooks/inject-context.js",
        "matcher": "council__consult|council__init_session"
      },
      {
        "command": "node hooks/secure-read.js",
        "matcher": "read_file"
      }
    ]
  }
}
